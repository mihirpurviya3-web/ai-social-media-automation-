      "id": "b9739764-8e21-48f1-b60b-2b3d68551430",
      "name": "Fetch YouTube Trending",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        224,
        384
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "\nconst allItems = $input.all();\nconst topics = [];\n\nfor (const item of allItems) {\n  const json = item.json;\n  \n  if (json.data && json.data.children) {\n    for (const post of json.data.children) {\n      if (post.data && post.data.score > 1000) {\n        topics.push({ source: 'reddit', title: post.data.title, score: post.data.score, comments: post.data.num_comments });\n      }\n    }\n  }\n  \n  if (json.items && Array.isArray(json.items)) {\n    for (const video of json.items) {\n      topics.push({ source: 'youtube', title: video.snippet ? video.snippet.title : 'Unknown', viewCount: video.statistics ? parseInt(video.statistics.viewCount || 0) : 0 });\n    }\n  }\n  \n  if (typeof json.data === 'string' && json.data.includes('<title>')) {\n    const matches = json.data.match(/<item>.*?<title>(.*?)<\\/title>.*?<\\/item>/gs);\n    if (matches) {\n      for (const match of matches) {\n        const titleMatch = match.match(/<title>(.*?)<\\/title>/);\n        if (titleMatch) {\n          topics.push({ source: 'google_trends', title: titleMatch[1].replace('<![CDATA[', '').replace(']]>', '').trim() });\n        }\n      }\n    }\n  }\n}\n\nconst sorted = topics.sort((a, b) => (b.score || b.viewCount || 0) - (a.score || a.viewCount || 0));\nconst top5 = sorted.slice(0, 5);\n\nif (top5.length === 0) {\n  return [{ json: { topics: [], count: 0, fetchedAt: new Date().toISOString() } }];\n}\n\nreturn [{ json: { topics: top5, count: top5.length, fetchedAt: new Date().toISOString() } }];\n      "
      },
