      "id": "7cdcc46a-2da3-46c6-8225-d56882d588a2",
      "name": "Format Topics for AI",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1120,
        96
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  try {\n    let rawText = '';\n    \n    // OpenAI response format\n    if (item.json.choices && Array.isArray(item.json.choices)) {\n      rawText = item.json.choices[0].message.content;\n    }\n    // Anthropic response format\n    else if (item.json.content && Array.isArray(item.json.content)) {\n      for (const block of item.json.content) {\n        if (block.text) rawText += block.text;\n      }\n    }\n    else if (item.json.text) {\n      rawText = item.json.text;\n    }\n    \n    const cleanText = rawText.replace(/```json/g, '').replace(/```/g, '').trim();\n    const parsed = JSON.parse(cleanText);\n    results.push({ json: { ...parsed, parsedAt: new Date().toISOString(), status: 'success' } });\n  } catch (e) {\n    results.push({ json: { error: 'Parse failed: ' + e.message, rawResponse: JSON.stringify(item.json).substring(0, 300), status: 'error', parsedAt: new Date().toISOString() } });\n  }\n}\nreturn results;\n"
      },
